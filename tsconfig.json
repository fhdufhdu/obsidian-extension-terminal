{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "outDir": ".",
    "rootDir": "src",
    "lib": ["ES2022", "DOM"],
    "sourceMap": false,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
